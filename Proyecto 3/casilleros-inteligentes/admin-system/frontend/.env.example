# Copia este archivo a .env y ajusta los valores.

# URL base de la API del backend Django.
# En desarrollo el backend suele correr en 8000 (o 8090 si 8000 esta ocupado).
VITE_API_URL=http://localhost:8000/api

# El login con Google NO se configura aqui: el Client ID se define en el backend
# (variable de entorno GOOGLE_OAUTH_CLIENT_ID) y el frontend lo consulta via
# GET /auth/config/. Asi hay una sola fuente de verdad. Ver docs/google-oauth.md.
